# A 股投研助手配置
# 复制此文件为 .env 并填入真实值

# === LLM ===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# === 数据源 ===
TUSHARE_TOKEN=

# === 功能开关 ===
USE_AKSHARE_HOTLIST=true
USE_CNINFO_PROVIDER=true

# === 存储路径 ===
TRACE_STORE_PATH=.local/trace.jsonl
USER_MEMORY_PATH=.local/user_memory.json

# === 运行环境 ===
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_ANALYSIS_MODE=single_stock
